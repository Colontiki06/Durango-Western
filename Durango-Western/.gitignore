```gitignore
# =========================
# DEPENDENCIAS
# =========================
node_modules/
backend/node_modules/
frontend/node_modules/

# =========================
# BUILD / COMPILADOS
# =========================
dist/
build/
tmp/
temp/
out-tsc/
bazel-out/

backend/dist/
frontend/dist/

# =========================
# ANGULAR
# =========================
.angular/
.angular/cache/

# =========================
# NESTJS
# =========================
backend/uploads/

# =========================
# VARIABLES DE ENTORNO
# =========================
.env
.env.local
.env.development
.env.production

backend/.env
frontend/.env

# =========================
# LOGS
# =========================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================
# TESTING / COVERAGE
# =========================
coverage/
.nyc_output/
test-results/

# =========================
# TYPESCRIPT
# =========================
*.tsbuildinfo

# =========================
# IDEs / EDITORES
# =========================

# VS CODE
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/mcp.json

# JetBrains
.idea/

# Eclipse
.project
.classpath
.settings/

# Cloud9
.c9/

# Sublime
*.sublime-workspace

# =========================
# HISTORIAL / CACHE
# =========================
.history/
.sass-cache/
.cache/

# =========================
# SISTEMA OPERATIVO
# =========================
.DS_Store
Thumbs.db

# =========================
# ARCHIVOS TEMPORALES
# =========================
*.tmp
*.temp
*.swp

# =========================
# SCREENSHOTS / REPORTES
# =========================
__screenshots__/
libpeerconnection.log
testem.log

# =========================
# ARCHIVOS GENERADOS
# =========================
typings/
lib/
```
